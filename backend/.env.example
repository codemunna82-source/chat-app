# Backend environment example (copy to .env for local dev; set same keys in Render dashboard)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/chat-app?retryWrites=true&w=majority
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000
SOCKET_URL=http://localhost:5000

# Optional: Redis adapter for Socket.io
# REDIS_URL=redis://default:password@redis-host:6379
