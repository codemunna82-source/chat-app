# Copy to `.env` for local development.

# --- MongoDB (pick ONE) ---
# Easiest when Atlas/DNS is blocked: in-memory DB (data lost on server stop; OK for local register/login testing)
MONGODB_URI=in-memory

# Local MongoDB daemon:
# MONGODB_URI=mongodb://127.0.0.1:27017/chat-app

# MongoDB Atlas (replace user, password, cluster host):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/chat-app?retryWrites=true&w=majority

# Comma-separated browser origins for CORS. Use full URL with correct port: http://localhost:3000
CLIENT_URL=http://localhost:3000

# Optional: public URLs for Helmet CSP (defaults shown)
# API_URL=http://localhost:5000
# SOCKET_URL=http://localhost:5000

# Optional: Redis adapter for Socket.io
# REDIS_URL=redis://default:password@redis-host:6379
