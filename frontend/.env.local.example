# Frontend environment example (copy to `.env.local` for local dev)
#
# LOCAL DEV (Express on port 5000):
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
#
# HOSTED API (URL must end with /api — not the bare host):
# NEXT_PUBLIC_API_URL=https://your-service.onrender.com/api
# NEXT_PUBLIC_SOCKET_URL=https://your-service.onrender.com
# Optional: override WebRTC ICE (JSON). Use a TURN service if audio/video fails on strict NATs:
# NEXT_PUBLIC_ICE_SERVERS={"iceServers":[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:YOUR_TURN","username":"u","credential":"p"}]}
# Or set TURN via separate vars (merged with default STUN):
# NEXT_PUBLIC_TURN_URLS=turn:global.turn.twilio.com:3478?transport=tcp
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=
